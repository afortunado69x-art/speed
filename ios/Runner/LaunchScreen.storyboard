<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB"
          version="3.0" toolsVersion="21701" targetRuntime="AppleCocoa"
          propertyAccessControl="none" useAutolayout="YES"
          launchScreen="YES" useTraitCollections="YES"
          useSafeAreas="YES" colorMatched="YES"
          initialViewController="01J-lp-oVM">

  <device id="retina6_12" orientation="portrait" appearance="dark"/>
  <dependencies>
    <deployment identifier="iOS"/>
    <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="21679"/>
    <capability name="Safe area layout guides" minToolsVersion="9.0"/>
    <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
  </dependencies>

  <scenes>
    <scene sceneID="EHf-IW-A2E">
      <objects>
        <viewController id="01J-lp-oVM" sceneMemberID="viewController">
          <view key="view" contentMode="scaleToFill" id="Ze5-6b-2t3">

            <!-- Root background: gothic void #0D0A0F -->
            <rect key="frame" x="0" y="0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>

              <!-- Dark background -->
              <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO"
                    id="bg-main">
                <rect key="frame" x="0" y="0" width="393" height="852"/>
                <color key="backgroundColor" red="0.051" green="0.039" blue="0.059" alpha="1"/>
              </view>

              <!-- Center logo image -->
              <imageView clipsSubviews="YES" userInteractionEnabled="NO"
                         contentMode="scaleAspectFit"
                         image="LaunchImage"
                         translatesAutoresizingMaskIntoConstraints="NO"
                         id="center-logo">
                <rect key="frame" x="136.5" y="350" width="120" height="152"/>
              </imageView>

              <!-- Gold ornament top line -->
              <view contentMode="scaleToFill"
                    translatesAutoresizingMaskIntoConstraints="NO"
                    id="top-line">
                <rect key="frame" x="40" y="60" width="313" height="1"/>
                <color key="backgroundColor" red="0.784" green="0.627" blue="0.251" alpha="0.3"/>
              </view>

              <!-- Gold ornament bottom line -->
              <view contentMode="scaleToFill"
                    translatesAutoresizingMaskIntoConstraints="NO"
                    id="bot-line">
                <rect key="frame" x="40" y="791" width="313" height="1"/>
                <color key="backgroundColor" red="0.784" green="0.627" blue="0.251" alpha="0.3"/>
              </view>

            </subviews>

            <viewLayoutGuide key="safeAreaLayoutGuide" id="Bcu-3y-fUS"/>
            <color key="backgroundColor" red="0.051" green="0.039" blue="0.059" alpha="1"/>

            <constraints>
              <constraint firstItem="bg-main" firstAttribute="leading" secondItem="Ze5-6b-2t3" secondAttribute="leading" id="c1"/>
              <constraint firstItem="bg-main" firstAttribute="trailing" secondItem="Ze5-6b-2t3" secondAttribute="trailing" id="c2"/>
              <constraint firstItem="bg-main" firstAttribute="top" secondItem="Ze5-6b-2t3" secondAttribute="top" id="c3"/>
              <constraint firstItem="bg-main" firstAttribute="bottom" secondItem="Ze5-6b-2t3" secondAttribute="bottom" id="c4"/>
              <constraint firstItem="center-logo" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="cx"/>
              <constraint firstItem="center-logo" firstAttribute="centerY" secondItem="Ze5-6b-2t3" secondAttribute="centerY" constant="-30" id="cy"/>
              <constraint firstItem="center-logo" firstAttribute="width" constant="120" id="cw"/>
              <constraint firstItem="center-logo" firstAttribute="height" constant="152" id="ch"/>
            </constraints>
